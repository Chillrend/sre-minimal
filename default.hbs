<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <title>{{meta_title}}</title>
  <link rel="canonical" href="{{canonical_url}}">

  {{!-- Favicon --}}
  {{#if @site.icon}}
    <link rel="icon" href="{{img_url @site.icon}}" type="image/png">
  {{/if}}

  {{!-- Fonts (preconnect for performance) --}}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600&family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">

  {{!-- Theme CSS (compiled by Gulp) --}}
  <link rel="stylesheet" type="text/css" href="{{asset "built/screen.css"}}">

  {{!-- Page-specific styles --}}
  {{{block "styles"}}}

  {{!-- Ghost head: outputs title, description, OG, Twitter Card, structured data, member scripts --}}
  {{ghost_head}}
</head>

<body class="{{body_class}} min-h-screen flex flex-col">

  {{!-- Reading progress bar (visible only on posts) --}}
  <div id="reading-progress" aria-hidden="true"></div>

  {{!-- Header / Navigation --}}
  {{> header}}

  {{!-- ── Main Content ──────────────────────────────────────────────────── --}}
  <main id="gh-main" class="flex-1 w-full" tabindex="-1">
    {{{body}}}
  </main>

  {{!-- ── Footer ────────────────────────────────────────────────────────── --}}
  <footer class="mt-24 border-t border-gx-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        {{!-- Brand + tagline --}}
        <div class="space-y-3">
          <a href="{{@site.url}}" class="flex items-center gap-2 group w-fit no-underline">
            <div class="w-6 h-6 rounded-gx-md bg-gx-tertiary flex items-center justify-center flex-shrink-0">
              <span class="text-gx-on-primary font-mono text-label font-bold leading-none">&gt;_</span>
            </div>
            <span class="font-display font-semibold text-gx-primary text-sm group-hover:text-gx-tertiary transition-colors">
              {{@site.title}}
            </span>
          </a>
          {{#if @site.description}}
            <p class="text-gx-secondary text-label leading-relaxed max-w-xs">{{@site.description}}</p>
          {{/if}}
          <div class="status-pill w-fit">all systems operational</div>
        </div>

        {{!-- Navigation links --}}
        <div class="space-y-2">
          <p class="font-mono text-label text-gx-secondary/50 mb-3">// links</p>
          {{navigation type="secondary"}}
        </div>

        {{!-- Terminal uptime block --}}
        <div class="footer-terminal">
          <p class="text-gx-secondary/50 mb-2">// system info</p>
          <p>
            <span class="text-gx-tertiary">$</span>
            <span class="text-gx-secondary"> uptime --since "{{@site.url}}"</span>
          </p>
          <p>
            <span class="text-gx-secondary/50">&gt;</span>
            <span class="text-gx-secondary"> © {{date format="YYYY"}} {{@site.title}}</span>
          </p>
          <p>
            <span class="text-gx-secondary/50">&gt;</span>
            <span class="text-gx-secondary"> Built with </span>
            <a href="https://ghost.org" class="text-gx-tertiary hover:opacity-80 transition-opacity" target="_blank" rel="noopener">Ghost</a>
            <span class="text-gx-secondary"> + </span>
            <span class="text-gx-tertiary">SRE-Minimalist</span>
          </p>
          <p>
            <span class="text-gx-secondary/50">&gt;</span>
            <span class="text-gx-tertiary"> STATUS: </span>
            <span class="text-gx-tertiary">OPERATIONAL ✓</span>
          </p>
        </div>

      </div>

    </div>
  </footer>

  {{!-- Theme JS --}}
  <script src="{{asset "built/main.min.js"}}"></script>

  {{!-- Page-specific scripts --}}
  {{{block "scripts"}}}

  {{!-- Ghost foot (Portal, Koenig editor scripts) --}}
  {{ghost_foot}}

</body>
</html>
