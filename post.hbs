{{!< default}}
{{!-- post.hbs — Single Post / Technical Whitepaper Reading View --}}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="max-w-wide mx-auto">

    {{#post}}

    <article class="{{post_class}}" itemscope itemtype="https://schema.org/Article">

      {{!-- ── Breadcrumb ──────────────────────────────────────────────────── --}}
      <nav class="flex items-center gap-2 font-mono text-label text-gx-secondary mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-gx-tertiary transition-colors no-underline">~</a>
        <span>/</span>
        {{#primary_tag}}
          <a href="{{url}}" class="hover:text-gx-tertiary transition-colors no-underline">{{name}}</a>
          <span>/</span>
        {{/primary_tag}}
        <span class="text-gx-secondary truncate max-w-[30ch]">{{title}}</span>
      </nav>

      {{!-- ── Post Header ──────────────────────────────────────────────────── --}}
      <header class="mb-10 space-y-4">

        {{!-- Tag & reading time --}}
        <div class="flex items-center gap-3 flex-wrap">
          {{#primary_tag}}
            <a href="{{url}}" class="mono-badge no-underline">{{name}}</a>
          {{/primary_tag}}
          {{#if featured}}
            <span class="mono-badge border-amber-500/40 text-amber-400">★ featured</span>
          {{/if}}
          <span class="font-mono text-label text-gx-secondary">{{reading_time}}</span>
        </div>

        {{!-- Title --}}
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-display font-semibold text-gx-primary leading-tight tracking-tight"
            itemprop="headline">
          {{title}}
        </h1>

        {{!-- Custom excerpt as subtitle --}}
        {{#if custom_excerpt}}
          <p class="text-gx-secondary text-lg leading-relaxed">{{custom_excerpt}}</p>
        {{/if}}

        {{!-- Author & meta bar --}}
        <div class="flex items-center gap-4 pt-4 border-t border-gx-border flex-wrap">
          {{#primary_author}}
            <div class="flex items-center gap-2" itemprop="author" itemscope itemtype="https://schema.org/Person">
              {{#if profile_image}}
                <img src="{{img_url profile_image size="xs"}}"
                     alt="{{name}}"
                     class="w-8 h-8 rounded-full border border-gx-border object-cover"
                     itemprop="image">
              {{else}}
                <div class="w-8 h-8 rounded-full bg-gx-tertiary flex items-center justify-center flex-shrink-0">
                  <span class="font-mono text-gx-on-primary text-sm font-bold leading-none">&gt;_</span>
                </div>
              {{/if}}
              <a href="{{url}}" class="font-mono text-label text-gx-secondary hover:text-gx-tertiary transition-colors no-underline"
                 itemprop="name">{{name}}</a>
            </div>
          {{/primary_author}}

          <span class="text-gx-border hidden sm:inline">·</span>

          <time class="font-mono text-label text-gx-secondary"
                datetime="{{date format="YYYY-MM-DD"}}"
                itemprop="datePublished">
            {{date format="MMMM D, YYYY"}}
          </time>

          {{#if updated_at}}
            <span class="font-mono text-label text-gx-secondary">
              (updated {{date updated_at format="MMM D, YYYY"}})
            </span>
          {{/if}}
        </div>

      </header>

      {{!-- ── Feature Image ────────────────────────────────────────────────── --}}
      {{#if feature_image}}
        <figure class="post-feature-image mb-10" itemprop="image" itemscope itemtype="https://schema.org/ImageObject">
          <img
            src="{{img_url feature_image size="l"}}"
            srcset="{{img_url feature_image size="s"}} 300w,
                    {{img_url feature_image size="m"}} 600w,
                    {{img_url feature_image size="l"}} 1000w,
                    {{img_url feature_image size="xl"}} 2000w"
            sizes="(max-width: 1280px) 100vw, 1280px"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            class="w-full h-full object-cover"
            itemprop="url"
            loading="eager"
          >
          {{#if feature_image_caption}}
            <figcaption class="mt-3 text-center font-mono text-label text-gx-secondary">
              {{{feature_image_caption}}}
            </figcaption>
          {{/if}}
        </figure>
      {{/if}}

      {{!-- ── Post Body ────────────────────────────────────────────────────── --}}
      <section class="gh-content is-body" itemprop="articleBody">
        {{content}}
      </section>

      {{!-- ── Post Footer ──────────────────────────────────────────────────── --}}
      <footer class="mt-16 space-y-10">

        {{!-- Tags list --}}
        {{#if tags}}
          <div class="flex flex-wrap gap-2">
            <span class="font-mono text-label text-gx-secondary mr-1">// tags</span>
            {{#foreach tags}}
              <a href="{{url}}" class="mono-badge no-underline">{{name}}</a>
            {{/foreach}}
          </div>
        {{/if}}

        <hr class="section-divider">

        {{!-- Author card --}}
        {{#primary_author}}
          <div class="author-card">
            {{#if profile_image}}
              <img src="{{img_url profile_image size="xs"}}"
                   alt="{{name}}"
                   class="author-card-avatar">
            {{else}}
              <div class="w-12 h-12 rounded-full bg-gx-tertiary flex items-center justify-center flex-shrink-0">
                <span class="font-mono text-gx-on-primary text-lg font-bold">&gt;_</span>
              </div>
            {{/if}}
            <div class="space-y-1 flex-1">
              <p class="author-card-name">{{name}}</p>
              {{#if bio}}
                <p class="author-card-bio">{{bio}}</p>
              {{/if}}
              <div class="flex items-center gap-3 mt-2">
                {{#if website}}
                  <a href="{{website}}" class="nav-link text-label" target="_blank" rel="noopener">web</a>
                {{/if}}
                {{#if twitter}}
                  <a href="https://twitter.com/{{twitter}}" class="nav-link text-label" target="_blank" rel="noopener">twitter</a>
                {{/if}}
                <a href="{{url}}" class="nav-link text-label">all posts →</a>
              </div>
            </div>
          </div>
        {{/primary_author}}

        {{!-- Post Navigation --}}
        <nav class="grid grid-cols-1 sm:grid-cols-2 gap-4" aria-label="Post navigation">
          {{#prev_post}}
            <a href="{{url}}" class="glass-card p-5 group flex flex-col gap-2 no-underline">
              <span class="font-mono text-label text-gx-secondary">← previous</span>
              <span class="font-display font-medium text-gx-primary text-sm group-hover:text-gx-tertiary transition-colors line-clamp-2">
                {{title}}
              </span>
            </a>
          {{/prev_post}}
          {{#next_post}}
            <a href="{{url}}" class="glass-card p-5 group flex flex-col gap-2 no-underline sm:items-end">
              <span class="font-mono text-label text-gx-secondary">next →</span>
              <span class="font-display font-medium text-gx-primary text-sm group-hover:text-gx-tertiary transition-colors line-clamp-2 sm:text-right">
                {{title}}
              </span>
            </a>
          {{/next_post}}
        </nav>

      </footer>

    </article>

    {{/post}}

  </div>
</div>
