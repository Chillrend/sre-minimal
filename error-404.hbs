{{!< default}}
{{!-- error-404.hbs — 404 Not Found: Terminal "Kernel Panic" Aesthetic --}}

<div class="min-h-[70vh] flex flex-col items-center justify-center px-4 py-24">
  <div class="w-full max-w-2xl space-y-8">

    {{!-- ── Terminal Block ───────────────────────────────────────────────── --}}
    <div class="terminal-block">

      <p class="terminal-error text-lg mb-4">
        KERNEL PANIC — NOT SYNCING: 404 Not Found
      </p>

      <p class="terminal-muted">CPU: 0 PID: 1 Comm: Ghost.hbs Not tainted</p>
      <p class="terminal-muted">Hardware name: {{@site.title}} / Ghost 5.x on x86_64</p>
      <p></p>

      <p>
        <span class="text-indigo-400">Process:</span>
        <span class="text-zinc-400"> nginx [segfault at 0x00000000404]</span>
      </p>
      <p>
        <span class="text-indigo-400">Kernel:</span>
        <span class="text-zinc-400"> {{@site.title}} blog-kernel 5.x-ghost-sre</span>
      </p>

      <p class="mt-3">
        <span class="terminal-warn">WARNING:</span>
        <span class="text-zinc-400"> Requested resource not found in filesystem.</span>
      </p>

      <p class="mt-3 terminal-muted">$ Attempting page recovery...</p>
      <p class="terminal-warn mt-1">
        &gt; ERROR: "{{url absolute="true"}}" not found.
      </p>
      <p class="terminal-muted">&gt; Searched: /, /posts/, /pages/, /api/</p>
      <p class="terminal-muted">&gt; Result: NULL</p>

      <p class="mt-4 terminal-muted">
        $ find / -name "what-you-were-looking-for" 2&gt;/dev/null
      </p>
      <p class="text-zinc-700">(no results)</p>

      <p class="mt-4">
        <span class="terminal-ok">●</span>
        <span class="text-zinc-400"> All other systems nominal. This page alone is missing.</span>
      </p>

      {{!-- Blinking prompt --}}
      <p class="mt-4">
        <span class="text-emerald-500">$</span>
        <span class="terminal-cursor ml-1" aria-label="Command prompt"></span>
      </p>
    </div>

    {{!-- ── Recovery Actions ─────────────────────────────────────────────── --}}
    <div class="flex flex-wrap gap-4">
      <a href="/" class="btn-primary">
        ← return to base
      </a>
      <a href="/search/" class="btn-ghost">
        $ search for it
      </a>
      <button onclick="history.back()" class="btn-ghost">
        ↩ go back
      </button>
    </div>

    {{!-- ── System Info Footer ──────────────────────────────────────────── --}}
    <div class="footer-terminal">
      <p class="text-zinc-700">// diagnostic report generated at: <span id="err-time" class="text-zinc-600"></span></p>
      <p class="text-zinc-700">// incident logged. no action required.</p>
    </div>

  </div>
</div>

<script>
  document.getElementById('err-time').textContent = new Date().toISOString();
</script>
