{{!< default}} {{!-- index.hbs — Homepage --}} <div id="gh-home">

  {{!-- ── HERO SECTION ─────────────────────────────────────────────────────── --}}
  <section class="relative min-h-[85vh] flex flex-col justify-center pb-24 overflow-hidden">

    {{!-- Grid dot background texture --}}
    <div class="absolute inset-0 grid-overlay pointer-events-none" aria-hidden="true"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">

      {{!-- System status pill --}}
      <div class="mb-8 animate-fade-in">
        <div class="status-pill w-fit">all systems operational</div>
      </div>

      {{!-- Animated headline --}}
      <div class="space-y-2 mb-8">
        <h1
          class="text-4xl sm:text-5xl lg:text-display font-display font-semibold text-gx-primary leading-tight tracking-tight">
          Hi, I'm an engineer.
        </h1>
        <h1
          class="text-4xl sm:text-5xl lg:text-display font-display font-semibold text-gx-primary leading-tight tracking-tight">
          I write&nbsp;<span id="anim-target" class="home-strike-target text-gx-secondary">efficient</span>&nbsp;<span
            id="anim-after">codes</span>
        </h1>
      </div>

      {{!-- Bio --}}
      <div class="max-w-2xl space-y-4 text-gx-secondary text-body leading-relaxed mb-10 animate-fade-in"
        style="animation-delay:0.2s">
        <p>
          I architect infrastructure, deploy reliable systems, and keep networks secure.
          As a Site Reliability and DevOps Engineer, my focus is on building resilient foundations—whether
          that means scaling environments for thousands of concurrent users or optimizing bare-metal setups.
          I believe the best infrastructure is the kind nobody notices.
        </p>
        <p>
          <a href="#" onclick="window.location.href = 'mailto:' + 'madjscriptcoder' + '@' + 'gmail.com'; return false;"
            class="inline-flex items-center gap-2 text-gx-tertiary
                    font-mono text-label transition-opacity duration-200 group no-underline hover:opacity-80">
            LET'S HAVE A CHAT
            <span class="group-hover:translate-x-1 transition-transform duration-200">→</span>
          </a>
        </p>
      </div>

      {{!-- Quick stats row --}}
      <div class="flex flex-wrap gap-6 font-mono text-label text-gx-secondary animate-fade-in"
        style="animation-delay:0.4s">
        <span><span class="text-gx-tertiary">●</span> Virtualization / Containerization </span>
        <span><span class="text-gx-tertiary">●</span> Networking </span>
        <span><span class="text-gx-tertiary">●</span> Monitoring </span>
        <span><span class="text-gx-tertiary">●</span> CI/CD </span>
        <span><span class="text-gx-tertiary">●</span> Security &amp; Privacy </span>
      </div>

    </div>
  </section>

  {{!-- ── MAIN CONTENT ────────────────────────────────────────────────────── --}}
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-24 space-y-24">

    {{!-- ── THE STACK SECTION ──────────────────────────────────────────────── --}}
    <section id="stack" aria-labelledby="stack-heading">
      <hr class="section-divider">

      <div class="mb-10">
        <h2 id="stack-heading" class="text-h1 font-display font-semibold text-gx-primary mb-2">
          // The Stack
        </h2>
        <p class="text-gx-secondary text-body max-w-2xl">
          Software is only as good as the infrastructure it runs on. Here is the toolbelt
          I use to ensure high availability, visibility, and security across the network.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        {{!-- Virtualization --}}
        <div class="glass-card p-6 border-l-2 border-l-gx-tertiary space-y-3">
          <h3 class="font-display font-semibold text-gx-primary text-sm">
            Virtualization &amp; Containers
          </h3>
          <p class="text-gx-secondary text-sm leading-relaxed">
            Managing bare-metal hypervisors and containerized workloads for efficient
            resource allocation and isolated environments.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="mono-badge">Proxmox</span>
            <span class="mono-badge">ESXi</span>
            <span class="mono-badge">Docker</span>
            <span class="mono-badge">Linux</span>
          </div>
        </div>

        {{!-- Networking --}}
        <div class="glass-card p-6 border-l-2 border-l-gx-tertiary space-y-3">
          <h3 class="font-display font-semibold text-gx-primary text-sm">
            Networking &amp; Infrastructure
          </h3>
          <p class="text-gx-secondary text-sm leading-relaxed">
            Routing, bandwidth management, and maintaining a Single Source of Truth
            for complex network topologies.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="mono-badge">MikroTik</span>
            <span class="mono-badge">NetBox</span>
            <span class="mono-badge">RADIUS</span>
          </div>
        </div>

        {{!-- Observability --}}
        <div class="glass-card p-6 border-l-2 border-l-gx-tertiary space-y-3">
          <h3 class="font-display font-semibold text-gx-primary text-sm">
            Observability &amp; Storage
          </h3>
          <p class="text-gx-secondary text-sm leading-relaxed">
            Keeping a pulse on system health through metrics, and managing distributed
            or high-throughput storage systems.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="mono-badge">Grafana</span>
            <span class="mono-badge">Prometheus</span>
            <span class="mono-badge">SeaweedFS</span>
            <span class="mono-badge">Frigate</span>
          </div>
        </div>

        {{!-- Automation --}}
        <div class="glass-card p-6 border-l-2 border-l-gx-tertiary space-y-3">
          <h3 class="font-display font-semibold text-gx-primary text-sm">
            Automation &amp; Security
          </h3>
          <p class="text-gx-secondary text-sm leading-relaxed">
            Writing internal tools to automate incident response workflows and
            securing organizational endpoints.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="mono-badge">CSIRT Ops</span>
            <span class="mono-badge">Node.js</span>
            <span class="mono-badge">Next.js</span>
          </div>
        </div>

      </div>
    </section>

    {{!-- ── IN THE TRENCHES — PROJECTS ─────────────────────────────────────── --}}
    <section id="projects" aria-labelledby="projects-heading">
      <hr class="section-divider">

      <div class="mb-10">
        <h2 id="projects-heading" class="text-h1 font-display font-semibold text-gx-primary mb-2">
          // In The Trenches
        </h2>
        <p class="text-gx-secondary text-body max-w-2xl">
          My big, real-world deployments that required getting hands dirty at every layer of the stack.
        </p>
      </div>

      <div class="space-y-4">

        {{!-- Project 01 --}}
        <div class="glass-card p-6 flex gap-6 group">
          <div class="log-prefix flex-shrink-0 pt-0.5 select-none transition-colors group-hover:text-gx-tertiary">[01]
          </div>
          <div class="space-y-2">
            <h3
              class="font-display font-semibold text-gx-primary text-sm group-hover:text-gx-tertiary transition-colors">
              High-Concurrency LMS Deployment
            </h3>
            <p class="text-gx-secondary text-sm leading-relaxed">
              Architected a highly optimized Moodle instance designed to handle concurrent testing
              loads for 4,500 users. Fine-tuned virtualization resources and database performance to
              guarantee zero downtime during critical campus examination windows.
            </p>
            <div class="flex gap-2 pt-1">
              <span class="mono-badge">Google Cloud</span>
              <span class="mono-badge">Compute</span>
              <span class="mono-badge">Load Balancing</span>
            </div>
          </div>
        </div>

        {{!-- Project 02 --}}
        <div class="glass-card p-6 flex gap-6 group">
          <div class="log-prefix flex-shrink-0 pt-0.5 select-none transition-colors group-hover:text-gx-tertiary">[02]
          </div>
          <div class="space-y-2">
            <h3
              class="font-display font-semibold text-gx-primary text-sm group-hover:text-gx-tertiary transition-colors">
              Institutional Network Modernization
            </h3>
            <p class="text-gx-secondary text-sm leading-relaxed">
              Centralized organizational network authentication by migrating to a robust RADIUS infrastructure.
              Redesigned bandwidth management policies to ensure equitable resource distribution, drastically
              reducing network congestion complaints across the institution.
            </p>
            <div class="flex gap-2 pt-1">
              <span class="mono-badge">Mikrotik</span>
              <span class="mono-badge">Radius</span>
              <span class="mono-badge">Traffic Engineering</span>
            </div>
          </div>
        </div>

        {{!-- Project 03 --}}
        <div class="glass-card p-6 flex gap-6 group">
          <div class="log-prefix flex-shrink-0 pt-0.5 select-none transition-colors group-hover:text-gx-tertiary">[03]
          </div>
          <div class="space-y-2">
            <h3
              class="font-display font-semibold text-gx-primary text-sm group-hover:text-gx-tertiary transition-colors">
              Infrastructure Single Source of Truth
            </h3>
            <p class="text-gx-secondary text-sm leading-relaxed">
              Spearheaded the transition from fragmented spreadsheets to a structured, API-accessible database.
              Deployed a centralized IPAM and DCIM system, streamlining infrastructure tracking and bringing order
              to complex network topologies
            </p>
            <div class="flex gap-2 pt-1">
              <span class="mono-badge">NetBox</span>
              <span class="mono-badge">IPAM</span>
              <span class="mono-badge">REST API</span>
            </div>
          </div>
        </div>

        {{!-- Project 04 --}}
        <div class="glass-card p-6 flex gap-6 group">
          <div class="log-prefix flex-shrink-0 pt-0.5 select-none transition-colors group-hover:text-gx-tertiary">[04]
          </div>
          <div class="space-y-2">
            <h3
              class="font-display font-semibold text-gx-primary text-sm group-hover:text-gx-tertiary transition-colors">
              CSIRT Incident Automation Tooling
            </h3>
            <p class="text-gx-secondary text-sm leading-relaxed">
              Developed automated incident response tooling using Node.js to handle large-scale security events.
              Built a streamlined password reset and ticketing pipeline that allowed support staff to rapidly
              secure compromised endpoints without bottlenecking daily operations.
            </p>
            <div class="flex gap-2 pt-1">
              <span class="mono-badge">Node.js</span>
              <span class="mono-badge">Incident Response</span>
              <span class="mono-badge">Automation</span>
            </div>
          </div>
        </div>

      </div>
    </section>

    {{!-- ── LATEST POSTS ─────────────────────────────────────────────────── --}}
    {{#get "posts" limit="6" include="tags,authors"}}
    {{#if posts}}
    <section id="posts" aria-labelledby="posts-heading">
      <hr class="section-divider">

      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 id="posts-heading" class="text-h1 font-display font-semibold text-gx-primary mb-2">
            // Latest Posts
          </h2>
          <p class="text-gx-secondary text-body">Writings from the trenches.</p>
        </div>
        <a href="/blog/" class="btn-ghost text-label">
          VIEW ALL →
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {{#foreach posts}}
        {{> post-card}}
        {{/foreach}}
      </div>
    </section>
    {{/if}}
    {{/get}}

  </div>
  </div>