{{!< default}}
{{!-- page.hbs — Static Page Layout (wide, clean) --}}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="max-w-wide mx-auto">

    {{#post}}

    <article class="{{post_class}}">

      {{!-- ── Page Header: conditionally shown via Ghost beta editor setting ── --}}
      {{#if @page.show_title_and_feature_image}}
      <header class="mb-12 space-y-4">

        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-mono font-bold text-zinc-100 leading-tight">
          {{title}}
        </h1>

        {{#if custom_excerpt}}
          <p class="text-zinc-400 text-xl leading-relaxed max-w-2xl">{{custom_excerpt}}</p>
        {{/if}}

        {{#if feature_image}}
          <figure class="post-feature-image mt-8">
            <img
              src="{{img_url feature_image size="l"}}"
              alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
              class="w-full h-full object-cover"
              loading="eager"
            >
            {{#if feature_image_caption}}
              <figcaption class="mt-3 text-center font-mono text-xs text-zinc-500">
                {{{feature_image_caption}}}
              </figcaption>
            {{/if}}
          </figure>
        {{/if}}

      </header>
      {{/if}}

      {{!-- ── Page Body ───────────────────────────────────────────────────── --}}
      <section class="gh-content is-body">
        {{content}}
      </section>

    </article>

    {{/post}}

  </div>
</div>
