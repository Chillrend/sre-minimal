{{!-- partials/navigation.hbs --}}
{{!-- Site header: logo, nav links, subscribe, mobile burger --}}

<header id="gh-head" class="
  fixed top-0 left-0 right-0 z-40
  border-b border-transparent
  transition-all duration-300
  bg-gx-neutral/0
  [&.is-scrolled]:bg-gx-neutral/90 [&.is-scrolled]:backdrop-blur-md [&.is-scrolled]:border-gx-border/80
">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      {{!-- ── Logo / Site Name ─────────────────────────────────────────── --}}
      <a href="{{@site.url}}" class="flex items-center gap-2 group no-underline" aria-label="{{@site.title}} home">
        {{#if @site.icon}}
          <img src="{{img_url @site.icon}}" alt="{{@site.title}}" class="w-7 h-7 rounded-gx-md">
        {{else}}
          {{!-- Default: terminal icon --}}
          <div class="w-7 h-7 rounded-gx-md bg-gx-tertiary flex items-center justify-center flex-shrink-0">
            <span class="text-gx-on-primary font-mono text-label font-bold leading-none">&gt;_</span>
          </div>
        {{/if}}
        <span class="font-display font-semibold text-gx-primary text-sm group-hover:text-gx-tertiary transition-colors">
          {{@site.title}}
        </span>
      </a>

      {{!-- ── Desktop Navigation ──────────────────────────────────────── --}}
      <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
        {{navigation}}
      </nav>

      {{!-- ── Right Controls ───────────────────────────────────────────── --}}
      <div class="flex items-center gap-3">

        {{!-- Search link --}}
        <a href="/search/" class="nav-link flex items-center gap-1.5" aria-label="Search">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <span class="hidden lg:inline">SEARCH</span>
        </a>

        {{!-- Ghost Portal Subscribe / Member Badge --}}
        {{#if @member}}
          <span class="mono-badge text-gx-tertiary border-gx-tertiary/40">
            ● member
          </span>
        {{else}}
          <a href="#/portal/signup"
             data-portal="signup"
             class="btn-primary hidden sm:inline-flex text-label py-1.5 px-3">
            subscribe
          </a>
        {{/if}}

        {{!-- Mobile Burger --}}
        <button id="nav-burger"
                class="md:hidden nav-link p-1 rounded-gx-md hover:bg-gx-surface transition-colors"
                aria-label="Open menu"
                aria-expanded="false"
                aria-controls="nav-overlay">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>

      </div>
    </div>
  </div>
</header>

{{!-- ── Mobile Nav Overlay ──────────────────────────────────────────────── --}}
<div id="nav-overlay"
     class="fixed inset-0 z-50 bg-gx-neutral/95 backdrop-blur-md
            flex flex-col
            translate-x-full opacity-0 pointer-events-none
            transition-all duration-300 ease-in-out">

  <div class="flex items-center justify-between px-6 h-16 border-b border-gx-border">
    <span class="font-mono text-label text-gx-secondary">// navigation</span>
    <button id="nav-close"
            class="p-1 rounded-gx-md text-gx-secondary hover:text-gx-primary hover:bg-gx-surface transition-colors"
            aria-label="Close menu">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <nav class="flex flex-col gap-1 p-6 flex-1" aria-label="Mobile navigation">
    {{navigation type="primary"}}
    <a href="/search/"
       class="flex items-center gap-3 px-3 py-3 rounded-gx-md font-mono text-label
              text-gx-secondary hover:bg-gx-surface hover:text-gx-primary transition-colors
              border border-transparent hover:border-gx-border no-underline">
      <svg class="w-4 h-4 text-gx-secondary/50" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      SEARCH
    </a>
  </nav>

  {{!-- Terminal footer in mobile nav --}}
  <div class="px-6 py-4 border-t border-gx-border">
    <p class="font-mono text-label text-gx-secondary">
      <span class="text-gx-tertiary">●</span> {{@site.title}} — all systems operational
    </p>
  </div>
</div>

{{!-- Spacer to push content below fixed header --}}
<div class="h-16"></div>
