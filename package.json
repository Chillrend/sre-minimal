{
  "name": "sre-minimalist",
  "description": "An engineering-first, dark-mode Ghost theme for SRE/infrastructure bloggers.",
  "version": "1.0.0",
  "license": "MIT",
  "author": {
    "name": "SRE-Minimalist",
    "email": "hello@example.com"
  },
  "keywords": ["ghost", "theme", "dark", "sre", "engineering", "tailwind"],
  "config": {
    "posts_per_page": 10,
    "image_sizes": {
      "xxs": { "width": 30 },
      "xs": { "width": 100 },
      "s": { "width": 300 },
      "m": { "width": 600 },
      "l": { "width": 1000 },
      "xl": { "width": 2000 }
    }
  },
  "custom": {
    "navigation_layout": {
      "type": "select",
      "options": ["Logo on the left", "Logo in the middle"],
      "default": "Logo on the left",
      "group": "header"
    },
    "show_featured_posts": {
      "type": "boolean",
      "default": true,
      "group": "homepage"
    }
  },
  "scripts": {
    "dev": "gulp",
    "build": "NODE_ENV=production gulp build",
    "zip": "npm run build && gulp zip",
    "test": "gscan ."
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.13",
    "autoprefixer": "^10.4.19",
    "cssnano": "^7.0.4",
    "gulp": "^5.0.0",
    "gulp-concat": "^2.6.0",
    "gulp-postcss": "^10.0.0",
    "gulp-rename": "^2.0.0",
    "gulp-uglify": "^3.0.2",
    "gulp-zip": "^6.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4"
  },
  "engines": {
    "ghost": ">=5.0.0"
  }
}
